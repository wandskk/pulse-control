# PostgreSQL (ex.: Neon — use a URL com pooler para serverless)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# SMS Dev — somente servidor (nunca NEXT_PUBLIC_*)
SMSDEV_KEY=

# URL de envio (padrão: https://api.smsdev.com.br/v1/send)
# SMSDEV_SEND_URL=

# Tipo de envio MT (padrão interno: 9). Só altere se o suporte SMS Dev indicar.
# SMSDEV_SEND_TYPE=9

# Se a SMS Dev não aceitar POST no seu plano, tente: SMSDEV_USE_GET=true
# SMSDEV_USE_GET=false

# Apenas em NODE_ENV=development: simula sucesso sem chamar a API
# SMSDEV_DRY_RUN=true

# Opcional — nome exibido no manifest PWA
# NEXT_PUBLIC_APP_NAME=PulseControl

# Autenticação multi-conta: defina AUTH_SECRET (mín. 16 caracteres) para exigir login.
# JWT em cookie httpOnly; usuários ficam na tabela User (Prisma).
# AUTH_SECRET=string-longa-aleatoria-min-16-chars

# Primeiro administrador (só na primeira vez, banco sem usuários):
# — Opção A: npm run db:seed com estas variáveis
# — Opção B: POST /api/auth/bootstrap com o mesmo e-mail e senha do corpo
# BOOTSTRAP_ADMIN_EMAIL=admin@exemplo.com
# BOOTSTRAP_ADMIN_PASSWORD=senha-forte-min-8

# Dev: origens extra para HMR (`/_next/*`) ao abrir por IP na rede. Lista separada por vírgula.
# Por defeito o next.config permite qualquer IPv4 (`*.*.*.*`). Para restringir, define só os hosts:
# NEXT_ALLOWED_DEV_ORIGINS=192.168.1.105,10.0.0.5
# Rede 192.168.x.x inteira (wildcard por segmento):
# NEXT_ALLOWED_DEV_ORIGINS=192.168.*.*
